// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// User model with authentication
model User {
  id            String    @id @default(cuid())
  email         String    @unique
  password      String    // Hashed with bcrypt
  name          String?
  avatar        String?
  role          UserRole  @default(USER)
  status        UserStatus @default(ACTIVE)
  
  // API Keys for programmatic access
  apiKeys       ApiKey[]
  
  // Generation history
  generations   Generation[]
  
  // Usage tracking
  usageStats    UsageStats?
  
  // Timestamps
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  lastLoginAt   DateTime?
  
  @@index([email])
  @@index([status])
  @@map("users")
}

model ApiKey {
  id          String    @id @default(cuid())
  name        String
  key         String    @unique // Hashed
  prefix      String    // First 8 chars for display
  
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId      String
  
  permissions String[]  @default(["read", "generate"])
  rateLimit   Int       @default(100) // Requests per hour
  
  lastUsedAt  DateTime?
  expiresAt   DateTime?
  
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  
  @@index([userId])
  @@index([key])
  @@map("api_keys")
}

model Generation {
  id            String            @id @default(cuid())
  
  user          User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId        String
  
  // Input
  prompt        String
  framework     String            @default("nextjs")
  styling       String            @default("tailwind")
  typescript    Boolean           @default(true)
  
  // Output
  code          String?           @db.Text
  previewUrl    String?
  
  // AI Provider info
  provider      String            @default("kimi")
  model         String            @default("kimi-k2-0711-preview")
  tokensUsed    Int?
  
  // Status
  status        GenerationStatus  @default(PENDING)
  error         String?
  
  // Metadata
  duration      Int?              // milliseconds
  ipAddress     String?
  userAgent     String?
  
  // Timestamps
  createdAt     DateTime          @default(now())
  completedAt   DateTime?
  
  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@map("generations")
}

model UsageStats {
  id                    String   @id @default(cuid())
  
  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId                String   @unique
  
  // Monthly usage
  month                 Int
  year                  Int
  
  // Counters
  totalGenerations      Int      @default(0)
  successfulGenerations Int      @default(0)
  failedGenerations     Int      @default(0)
  
  // Tokens
  totalTokensUsed       Int      @default(0)
  
  // Rate limiting
  requestsThisHour      Int      @default(0)
  hourWindowStart       DateTime @default(now())
  
  updatedAt             DateTime @updatedAt
  
  @@unique([userId, month, year])
  @@map("usage_stats")
}

model AuditLog {
  id          String   @id @default(cuid())
  
  action      String   // CREATE, UPDATE, DELETE, LOGIN, etc.
  entity      String   // User, Generation, etc.
  entityId    String?
  
  userId      String?
  userEmail   String?
  
  // Request details
  ipAddress   String?
  userAgent   String?
  
  // Changes
  oldValue    Json?
  newValue    Json?
  
  // Metadata
  metadata    Json?
  
  createdAt   DateTime @default(now())
  
  @@index([action])
  @@index([entity])
  @@index([userId])
  @@index([createdAt])
  @@map("audit_logs")
}

// Enums
enum UserRole {
  USER
  PREMIUM
  ADMIN
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  DELETED
}

enum GenerationStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  CANCELLED
}
